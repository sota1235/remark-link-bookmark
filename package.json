{
  "name": "@sota1235/remark-link-bookmark",
  "version": "0.0.8",
  "description": "Remark plugin to convert link to bookmark component",
  "main": "dist/index.js",
  "type": "module",
  "dependencies": {
    "@types/mdast": "4.0.4",
    "clsx": "2.1.1",
    "debug": "4.4.3",
    "dompurify": "3.3.3",
    "jsdom": "29.0.1",
    "open-graph-scraper": "6.11.0",
    "typescript": "^5.0.0",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@sota1235/eslint-config": "5.0.5",
    "@types/debug": "4.1.13",
    "@types/jsdom": "28.0.1",
    "@types/node": "25",
    "eslint": "10.1.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "remark": "15.0.1",
    "typescript-eslint": "8.58.0",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.publish.json",
    "build:publish": "tsc -p ./tsconfig.publish.json",
